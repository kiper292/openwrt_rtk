diff -urN luci_orig/build/module.mk luci_patch/build/module.mk
--- luci_orig/build/module.mk
+++ luci_patch/build/module.mk
@@ -20,7 +20,14 @@
 	for i in $$(find dist -name .svn -o -name .gitignore); do rm -rf $$i || true; done
   ifneq ($(PO),)
 	mkdir -p dist$(LUCI_I18NDIR)
+	ENABLED_LANGS="$$(grep 'CONFIG_PACKAGE_luci-i18n-.*=y' $(TOPDIR)/.config 2>/dev/null | sed 's/CONFIG_PACKAGE_luci-i18n-//;s/=y//' | tr '\n' ' ')"
 	for file in $(PO); do \
-	  cp $(HOST)/lua-po/$$file.$(if $(PO_LANG),$(PO_LANG),*).* dist$(LUCI_I18NDIR)/ 2>/dev/null || true; \
+	  if [ -n "$(PO_LANG)" ]; then \
+	    cp $(HOST)/lua-po/$$file.$(PO_LANG).* dist$(LUCI_I18NDIR)/ 2>/dev/null || true; \
+	  elif [ -n "$$ENABLED_LANGS" ]; then \
+	    for lang in $$ENABLED_LANGS; do \
+	      cp $(HOST)/lua-po/$$file.$$lang.* dist$(LUCI_I18NDIR)/ 2>/dev/null || true; \
+	    done; \
+	  fi; \
 	done
   endif
